# Set to "true" to enable Google Ads (Support section + right rail). Default: off.
# For GitHub Pages: set repository variable VITE_ADS_ENABLED in Settings → Actions → Variables.
# VITE_ADS_ENABLED=false

# Optional: Google AdSense publisher client ID (e.g. ca-pub-XXXXXXXXXXXXXXXX).
# Only used when VITE_ADS_ENABLED=true. When set, AdSlot components render live ads; when unset, placeholders are shown.
# VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Optional: Ad slot IDs for specific placements (used by AdSlot when VITE_ADS_ENABLED=true).
# VITE_ADSENSE_SLOT_SUPPORT=
# VITE_ADSENSE_SLOT_RAIL=
